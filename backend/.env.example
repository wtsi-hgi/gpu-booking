# Backend Environment Variables
# Copy this file to .env and adjust values as needed

# CORS origins (comma-separated list)
# Use "*" for development, specific origins for production
CORS_ORIGINS=http://localhost:3000

# Server configuration
BACKEND_PORT=8000

# Authentication mode: insecure (local dev) or oidc (production)
# Default in code is insecure if unset, but set explicitly for clarity.
AUTH_MODE=insecure

# OIDC / Okta settings (required when AUTH_MODE=oidc)
# Example: https://dev-123456.okta.com/oauth2/default
OKTA_ISSUER=
# Audience claim expected in access tokens.
# Leave empty only if your token validation policy does not require audience.
OKTA_AUDIENCE=

# Initial admin email list used for bootstrap/seed flows (comma-separated)
# Example: admin1@example.com,admin2@example.com
INITIAL_ADMIN_EMAILS=
