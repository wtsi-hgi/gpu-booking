# Backend environment variables
# Copy this file to .env and adjust values as needed.
#
# This file lists every app-specific environment variable currently accepted by
# `backend/config.py`. Some are informational or reserved for future use; those
# are called out explicitly below.

# API metadata
APP_NAME=LLM Knowledge Base API
APP_VERSION=0.1.0
APP_DESCRIPTION=FastAPI backend for Next.js + shadcn/ui frontend

# Server configuration
BACKEND_PORT=8000
# Accepted by settings, but `backend/run_uvicorn.sh` currently hard-codes the
# Uvicorn host and reload flag when it starts the dev server.
HOST=0.0.0.0
RELOAD=true

# Authentication mode: insecure (local dev) or oidc (bearer-token validation)
AUTH_MODE=insecure

# OIDC / Okta settings
# Required when AUTH_MODE=oidc.
# Example: https://dev-123456.okta.com/oauth2/default
# The backend accepts either the historical `OKTA_*` names below or the
# corresponding `OIDC_*` aliases used by the frontend.
# Examples:
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_AUDIENCE=
OKTA_ISSUER=
# Optional audience claim expected in access tokens.
# Leave empty only if your token validation policy does not require audience.
OKTA_AUDIENCE=
# Accepted by settings, but the current backend OIDC implementation only
# validates incoming bearer tokens and does not perform a client-id/client-
# secret based token exchange.
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=

# Database
# Keep this path valid for the machine running the backend. Relative SQLite
# paths resolve from the `backend/` directory because the dev server starts
# there.
DATABASE_URL=sqlite+aiosqlite:///./gpu_booking.db

# Admin bootstrap
# Comma-separated list used to seed/bootstrap admin users.
# Example: admin1@example.com,admin2@example.com
INITIAL_ADMIN_EMAILS=

# Observability / shared resources
LOG_LEVEL=INFO
HTTP_CLIENT_TIMEOUT=10.0
