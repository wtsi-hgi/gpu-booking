# Frontend environment variables
# Copy this file to .env.local and adjust values as needed.
#
# This file lists every app-specific environment variable currently used by the
# frontend code or dev launcher.

# Backend connection used by Next.js server actions and route handlers.
# If GPU_BOOKING_BACKEND_URL is set, it takes precedence over GPU_BOOKING_BACKEND_PORT.
GPU_BOOKING_BACKEND_URL=http://localhost:8000
GPU_BOOKING_BACKEND_PORT=8000

# Frontend dev server port.
GPU_BOOKING_FRONTEND_PORT=3000

# Frontend OIDC settings used by /auth/login, /auth/callback, and /auth/logout.
# The frontend exchanges the authorization code, stores the resulting bearer
# token in an HTTP-only cookie, and forwards it to the backend from server
# actions and server-rendered pages.
#
# Supported aliases for issuer and client details match backend conventions.
# These frontend variables are the preferred names:
GPU_BOOKING_OIDC_ISSUER_URL=
GPU_BOOKING_OIDC_CLIENT_ID=
GPU_BOOKING_OIDC_CLIENT_SECRET=

# Optional overrides. When unset, the frontend defaults to:
# - redirect URI: ${origin}/auth/callback
# - post logout redirect URI: ${origin}/
# - scopes: openid profile email
GPU_BOOKING_OIDC_REDIRECT_URI=
GPU_BOOKING_OIDC_POST_LOGOUT_REDIRECT_URI=
GPU_BOOKING_OIDC_SCOPES=
