# Frontend environment variables
# Copy this file to .env.local and adjust values as needed.
#
# This file lists every app-specific environment variable currently used by the
# frontend code or dev launcher.

# Backend connection used by Next.js server actions and route handlers.
# If BACKEND_URL is set, it takes precedence over BACKEND_PORT.
BACKEND_URL=http://localhost:8000
BACKEND_PORT=8000

# Frontend dev server port.
FRONTEND_PORT=3000

# The current frontend does not implement an Okta/OIDC login flow and does not
# read any `OIDC_*` or `OKTA_*` environment variables. If you set them in
# `frontend/.env.local`, they are ignored by the current codebase.
#
# Examples of currently ignored variables:
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=
# OIDC_POST_LOGOUT_REDIRECT_URI=
# OIDC_SCOPES=
