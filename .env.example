GPU_BOOKING_FRONTEND_PORT=3000
GPU_BOOKING_BACKEND_PORT=8000
GPU_BOOKING_AUTH_MODE=insecure
GPU_BOOKING_BACKEND_URL=http://127.0.0.1:8000
# Relative SQLite paths resolve from the backend process cwd; make run starts it in backend/.
GPU_BOOKING_DATABASE_URL=sqlite+aiosqlite:///./gpu_booking.db
GPU_BOOKING_INITIAL_ADMIN_EMAILS=admin@example.com
